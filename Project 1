void setup()
{
 pinMode(9, OUTPUT);
 pinMode(6, OUTPUT);
 pinMode(5, OUTPUT);
}

void loop()
{
  for(int r = 0; r < 255; r++)
  {
    analogWrite(9, 255 - r);
    analogWrite(6, r);
    delay(10);
  }
  for(int b = 0; b < 255; b++)
  {
    analogWrite(6, 255 - b);
    analogWrite(5, b);
    delay(10);
  }
  for(int g = 0; g < 255; g++)
  {
    analogWrite(5, 255 - g);
    analogWrite(9, g);
    delay(10);
  }
}
